def activation(out, threshold):
    return 1 if out >= threshold else 0

def perceptron(and_input):

    a=[0,0,1,1]
    b=[0,1,0,1]
    y=[0,0,0,1]

    w=[1.4,1.5]
    threshold=1
    lr=0.1

    i=0

    while i<4:

        sum = a[i]*w[0] + b[i]*w[1]
        o = activation(sum, threshold)

        if o != y[i]:

            w[0] += lr*(y[i]-o)*a[i]
            w[1] += lr*(y[i]-o)*b[i]

            i=-1

        i+=1

    sum = and_input[0]*w[0] + and_input[1]*w[1]

    return activation(sum, threshold)


print("AND Output:", perceptron([1,1]))

