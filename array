import numpy as np

X = np.array(([2,9],[1,5],[3,6]), dtype=float)

y = np.array(([92],[86],[89]), dtype=float)

X = X / np.amax(X, axis=0)

y = y / 100


def sigmoid(x):
    return 1/(1+np.exp(-x))

def derivatives_sigmoid(x):
    return x*(1-x)


epoch = 7000
lr = 0.1

inputlayer = 2
hiddenlayer = 3
outputlayer = 1

wh = np.random.uniform(size=(inputlayer, hiddenlayer))
bh = np.random.uniform(size=(1, hiddenlayer))

wout = np.random.uniform(size=(hiddenlayer, outputlayer))
bout = np.random.uniform(size=(1, outputlayer))


for i in range(epoch):

    hinp = np.dot(X, wh) + bh
    hlayer = sigmoid(hinp)

    outinp = np.dot(hlayer, wout) + bout
    output = sigmoid(outinp)

    EO = y - output

    d_output = EO * derivatives_sigmoid(output)

    EH = d_output.dot(wout.T)

    d_hidden = EH * derivatives_sigmoid(hlayer)

    wout += hlayer.T.dot(d_output) * lr
    wh += X.T.dot(d_hidden) * lr


print("Input")
print(X)

print("Actual Output")
print(y)

print("Predicted Output")
print(output)
